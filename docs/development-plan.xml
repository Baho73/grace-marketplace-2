    </Phase-0>

    <Phase-1 name="Activation Mechanisms" status="done">
      <goal>Make it hard for Claude Code to forget GRACE: meta-skill, SessionStart hook, CLAUDE.md preamble.</goal>
      <step-1 module="M-SKILLS-CANONICAL" status="done">Create `grace-bootstrap` meta-skill with EXTREMELY-IMPORTANT block and activation flowchart.</step-1>
      <step-2 module="M-CLI-STATUS" status="done" verification="V-M-CLI-STATUS">Implement `grace status` and `grace status --brief`.</step-2>
      <step-3 status="done">Add `settings.json.template` in grace-init assets for SessionStart hook.</step-3>
      <step-4 status="done">Add `CLAUDE.md.template` in grace-init assets with CRITICAL preamble.</step-4>
      <step-5 status="done">Update grace-init SKILL.md to emit CLAUDE.md and .claude/settings.json.</step-5>
      <checkpoint>Fresh `grace-init` produces CLAUDE.md + settings.json; `grace status --brief` exits 0 with &lt;=30 lines of output.</checkpoint>
    </Phase-1>

    <Phase-2 name="Skill Sweep" status="done">
      <goal>Apply three discipline sections to all 15 skills.</goal>
      <step-1 status="done">Add Common Rationalizations, When NOT to Use, Verification to every `skills/grace/*/SKILL.md`.</step-1>
      <checkpoint>`grep -c "Common Rationalizations"` returns 1 for every SKILL.md.</checkpoint>
    </Phase-2>

    <Phase-3 name="Deep Reworks" status="done">
      <goal>Substantive upgrades on the five most load-bearing skills.</goal>
      <step-1 status="done">Rewrite grace-fix around the Prove-It Pattern (Locate -> Prove -> Fix -> Verify -> Guard).</step-1>
      <step-2 status="done">Rewrite grace-reviewer with a 5-axis framework and severity labels.</step-2>
      <step-3 status="done">Add Wave Success Thresholds and Pre-Wave Checklist to grace-multiagent-execute.</step-3>
      <step-4 status="done">Add phases-with-checkpoints and dependency discipline to grace-plan.</step-4>
      <step-5 status="done">Rewrite grace-ask around progressive disclosure (4-level context hierarchy).</step-5>
      <checkpoint>Each of the five skills cites its new pattern in its frontmatter description.</checkpoint>
    </Phase-3>

    <Phase-4 name="CLI Support" status="done">
      <goal>CLI support for the new patterns.</goal>
      <step-1 module="M-CLI-STATUS" status="done" verification="V-M-CLI-STATUS">`grace status --brief` implemented and tested.</step-1>
      <step-2 module="M-LINT-SKILL-SECTIONS" status="done" verification="V-M-LINT-SKILL-SECTIONS">`grace lint` warns on missing skill sections.</step-2>
      <checkpoint>`bun test` green; `bun run ./scripts/validate-marketplace.ts` green.</checkpoint>
    </Phase-4>

    <Phase-5 name="Reference Project" status="in-progress">
      <goal>Grace-marketplace itself becomes a GRACE-managed project (reference example).</goal>
      <step-1 status="done">Create `docs/knowledge-graph.xml` describing CLI modules and skill collections.</step-1>
      <step-2 status="done">Create `docs/development-plan.xml` from PLAN.md content.</step-2>
      <step-3 status="done">Create `docs/verification-plan.xml` with V-M-xxx for each module.</step-3>
      <checkpoint>`grace lint --path .` exits 0 (warnings ok); `grace module find` returns expected module list.</checkpoint>
    </Phase-5>
  </ImplementationOrder>

  <ExecutionPolicy>
    <default-profile>balanced</default-profile>
    <controller-owns>docs/development-plan.xml, docs/knowledge-graph.xml, docs/verification-plan.xml, .claude-plugin/marketplace.json</controller-owns>
    <worker-owns>Single-module source edits under src/ and their module-local tests.</worker-owns>
    <mirror-discipline>Every change under `skills/grace/*` must be copied to `plugins/grace/skills/grace/*` in the same commit; validate-marketplace enforces this.</mirror-discipline>
  </ExecutionPolicy>
</DevelopmentPlan>
